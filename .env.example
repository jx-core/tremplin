# ----- Database -----
# In Docker Compose the host is the service name "db"; locally it's localhost.
DATABASE_URL=postgres://tremplin:tremplin@localhost:5432/tremplin

# ----- Admin auth (server-only, never exposed to the browser) -----
ADMIN_USERNAME=admin
# Either set a plaintext password (simplest) ...
ADMIN_PASSWORD=change-me
# ... or a bcrypt hash (takes priority if set). Generate: node -e "console.log(require('bcryptjs').hashSync('yourpass',10))"
ADMIN_PASSWORD_HASH=
# Secret used to sign the admin session cookie (use a long random string in production)
SESSION_SECRET=please-change-this-to-a-long-random-string

# ----- Public site -----
NEXT_PUBLIC_SITE_URL=https://tremplin.stonebase.tech
