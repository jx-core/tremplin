# Copy this to `.env` on the VPS, in the same directory as docker-compose.prod.yml,
# then fill in real values. Compose reads it automatically for ${VAR} substitution.

# Postgres password (used by the db service and the app/migrate DATABASE_URL).
POSTGRES_PASSWORD=change-this-strong-db-password

# Secret used to sign the admin session cookie. Use a long random string (>= 32 chars).
#   openssl rand -base64 48
SESSION_SECRET=replace-with-a-long-random-string

# Mini admin account.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
# Optional: bcrypt hash instead of plaintext (takes priority over ADMIN_PASSWORD). Generate:
#   docker run --rm node:22-alpine node -e "console.log(require('bcryptjs')?.hashSync||'')" 2>/dev/null
#   (or after deps install: node -e "console.log(require('bcryptjs').hashSync('yourpass',10))")
ADMIN_PASSWORD_HASH=
